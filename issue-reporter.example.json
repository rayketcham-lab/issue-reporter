{
  "project_name": "My Awesome App",
  "project_description": "A web app that does cool things",
  "repo_dir": ".",
  "ollama_model": "llama3",
  "issue_types": [
    {"id": "bug", "label": "Bug Report", "description": "Something is broken"},
    {"id": "feature_request", "label": "Feature Request", "description": "I want something new"},
    {"id": "data_issue", "label": "Data Issue", "description": "Data is wrong or missing"},
    {"id": "ui_bug", "label": "UI Bug", "description": "Visual or layout problem"},
    {"id": "performance", "label": "Performance", "description": "Something is slow"},
    {"id": "security", "label": "Security", "description": "Security concern"},
    {"id": "other", "label": "Other", "description": "Something else"}
  ],
  "label_map": {
    "bug": ["bug"],
    "feature_request": ["enhancement"],
    "data_issue": ["bug", "data"],
    "ui_bug": ["bug", "ui"],
    "performance": ["performance"],
    "security": ["security"],
    "other": ["bug"]
  },
  "valid_labels": ["bug", "enhancement", "data", "ui", "performance", "security", "critical", "documentation"]
}
